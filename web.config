<configuration>
  <system.webServer>

    <!-- iisnode handler — routes all requests through Node.js -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- URL Rewrite: send all requests to server.js -->
    <rewrite>
      <rules>
        <!-- Do not interfere with iisnode debugging/status -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^server.js\/debug[\/]?" />
        </rule>

        <!-- Static files served by IIS for performance (optional — Node handles them too) -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^public/(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="public/{R:1}" />
        </rule>

        <!-- All other requests go to Node.js -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode configuration -->
    <iisnode
      nodeProcessCommandLine="&quot;%programfiles%\nodejs\node.exe&quot;"
      watchedFiles="web.config;server.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      devErrorsEnabled="false"
      node_env="production"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
      flushResponse="false"
    />

    <!-- Block access to sensitive files -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="iisnode" />
          <add segment=".git" />
        </hiddenSegments>
        <denyUrlSequences>
          <add sequence="settings.json" />
          <add sequence="settings.example.json" />
          <add sequence="secureboot.db" />
          <add sequence="package.json" />
          <add sequence="package-lock.json" />
          <add sequence=".env" />
        </denyUrlSequences>
      </requestFiltering>
    </security>

    <!-- Custom error pages — don't leak server info -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
